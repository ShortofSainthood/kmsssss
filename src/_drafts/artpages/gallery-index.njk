<div class="gallery">
  {% set i = 0 %}
  {% for previewimage in pagination.items %}
  <div class="galleryimg {% if previewimage.warning %}warning{% endif %}" id="{% if previewimage.title %}{{ previewimage.title | slugify}}{% else %}{{ i + 1 }}{% endif %}">
    {% if previewimage.warning %}
      <a {% if previewimage.warning %}class="warninglink"{% endif %} href="/art/gallery/images/{% if previewimage.title %}{{ previewimage.title | slugify}}{% else %}{{ i + 1 }}{% endif %}.html">
        <img style="visibility: hidden;" src="/assets/images/art/{{ previewimage.img }}" alt="sensitive content">
      </a>
      <div class="warningcomment">
        {% lucide "triangle-alert", { "size": "32", "stroke-width": "2", "stroke": "var(--yellow)" } %}
        
        
        
        <p aria-hidden="true" style="margin: 0;">Sensitive Content</p>
      </div>

      {% else %}
      <a href="/art/gallery/images/{% if previewimage.title %}{{ previewimage.title | slugify}}{% else %}{{ i + 1 }}{% endif %}.html"><img style="{% if previewimage.pixelated %}image-rendering: pixelated; image-rendering: -moz-crisp-edges; image-rendering: crisp-edges;{% endif %}" src="/assets/images/art/{{ previewimage.img }}" alt="{{ previewimage.alt }}"></a>
    {% endif %}
  </div>
  {% set i = i + 1 %}
  {% endfor %}
</div>

