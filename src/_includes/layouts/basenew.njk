        @supports (background-color: color-mix(in srgb, var(--accent-primary) 40%, transparent)) {
            pre {
                border-color: color-mix(in srgb, var(--text) 30%, transparent);
            }
        }

        blockquote {
          border-left: 4px solid var(--accent-primary);
          padding: 1em;
          background-color: color-mix(in srgb, var(--accent-primary) 10%, transparent 90%);
        }

        li::marker, details:first-of-type summary::marker,
        :is(::-webkit-details-marker) {
          color: var(--accent-primary);
          font-weight: bold;
        }

        dt {
          font-weight: bold;
          color: color-mix(in srgb, var(--accent-primary) 25%, var(--text));
        }

        strong {
          color: color-mix(in srgb, var(--accent-primary) 50%, var(--text));
        }

        hr {
            border: none;
            border-top: 1px solid var(--accent-primary);
            color: var(--text);
            overflow: visible;
            text-align: center;
            height: /*5px*/ 0px;
            margin: 1em auto;
        }
        hr::after {
            background: var(--bg);
            content: "§";
            padding: 0 4px;
            position: relative;
            top: -0.85em;
            font-size: 0.9em;
        }

        fieldset {
          border: 1px solid var(--accent-primary);
        }

        details {
          background-color: color-mix(in srgb, var(--accent-primary) 10%, transparent 90%);
        }

        code {
          font-family: var(--codefont);
          /*font-size-adjust: 0.45;*/
        }

        del {
            background-color: color-mix(in srgb, var(--color-red) 40%, transparent);
            filter: saturate(120%);
          }

          ins {
            background-color: color-mix(in srgb, var(--color-green) 40%, transparent);
            filter: saturate(120%);
          }

          main ul {
            list-style-image: /*url("https://images-wixmp-ed30a86b8c4ca887773594c2.wixmp.com/f/25425fb2-bc94-4349-8d8a-6eabb4d6ccd2/dclib13-4e422936-aac3-43c0-9f36-939a8c9501a5.png?token=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..DgzxJi_8HxjampnUSa3gB9vmDFmiaQ3Z5Og94aaON1A")*/ var(--pixel);
          }
          main ul li li {
            list-style-image: none;
          }






          /* BUTTON AND FORM CONTROLS*/
input, textarea, select {
    background: color-mix(in srgb, var(--accent-primary) 10%, transparent 90%);
    color: var(--text);
    border: 1px solid currentColor;
    font-size: inherit;
    font-family: var(--bodyfont);
    padding: 5px;
    margin: 5px;
    border-radius: 5px;
}
button, select.altselect {
    color: var(--bg);
    background: var(--link);
    padding: 7px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    font-weight: bold;
    border: unset;
    font-size: inherit;
    font-family: inherit;
    border-radius: 5px;
    margin: 0.5em 0.1em;
}
button:hover, button:focus {background: var(--hover)}
option[disabled] {font-style: italic;}
fieldset {
    border: 2px solid var(--text);
    margin: 10px 5px;
    padding: 10px;
    border-radius: 8px;
}
legend {
    color: var(--bg);
    background: var(--text);
    font-weight: bold;
    padding: 5px 10px;
    border-radius: 15px;
}
select.altselect {background: var(--bg); color: var(--text); border: var(--text) 2px solid;}
select.altselect optgroup {background: var(--text); color: var(--bg);}
select.altselect option {font-weight: normal;}
input[type="checkbox"], input[type="radio"], input[type="range"], progress {accent-color: var(--accent-primary);}
@supports (color: color-mix(in oklab, var(--text), var(--bg) 40%)) {
    option:disabled {color: color-mix(in oklab, var(--text), var(--bg) 40%)}
}
/*
option:checked { color: var(--bg); background: var(--accent-primary);}
*/

/* TABLE */
table {border-collapse: collapse; margin: 0 auto; border-radius: 8px; overflow: clip;}
th, td {border: 1px solid; padding: 8px 10px;}
th, thead td, tfoot td {
    text-align: center;
    font-weight: bold;
    background: var(--text);
    color: var(--bg);
    border-color: var(--bg);
  }
td {border-color: var(--text)}
.zebra tr:nth-child(odd), .both tr:nth-child(odd) {background-color: var(--transparentbg);}
.vertical tbody td:nth-child(even), .both tbody td:nth-child(even) {background-color: var(--transparentbg);}
.zebra-odd tr:nth-child(even), .both-odd tr:nth-child(even) {background-color: var(--transparentbg);}
.vertical-odd tbody td:nth-child(odd), .both-odd tbody td:nth-child(odd) {background-color: var(--transparentbg);}
@supports (background: color-mix(in srgb, var(--text) 10%, var(--bg))) {
    .zebra tr:nth-child(odd), .both tr:nth-child(odd),
    .vertical tbody td:nth-child(even), .both tbody td:nth-child(even),
    .zebra-odd tr:nth-child(even), .both-odd tr:nth-child(even),
    .vertical-odd tbody td:nth-child(odd), .both-odd tbody td:nth-child(odd) {
        background: color-mix(in srgb, var(--text) 10%, var(--bg));
    }
    .both tr:nth-child(odd) td:nth-child(even),
    .both-odd tr:nth-child(even) td:nth-child(odd) {
        background: color-mix(in srgb, var(--text) 20%, var(--bg));
    }
}
caption {font-weight: bold; color: var(--textaccent);}










          /* SKIP TO CONTENT LINK */
          #skiptocontent a {
              padding: 6px 10px;
              position: absolute;
              top: -45px;
              left: 0px;
              color: var(--text);
              background: var(--bg);
              font-family: var(--headingfont);
              border-right: 5px solid var(--text);
              border-bottom: 5px solid var(--text);
              font-weight: bold;
              text-decoration: none;
              -webkit-transition: top 1s ease-out;
              transition: top 1s ease-out;
              z-index: 100;
              border-radius: 0;
          }
          #skiptocontent a:focus {
              position:absolute;
              left: 0px;
              top: 0px;
              outline-color:transparent;	
              -webkit-transition: top .1s ease-in;
              transition: top .1s ease-in;
              outline: 0;
              box-shadow: none;
          }
          @media (prefers-reduced-motion: reduce) {
              #skiptocontent a {
                  transition-duration: 0s!important;
              }
          }





        @media screen and (min-width: 1025px) {
            #main { border-width: 0 2px 0 0;}
            #sidebar {
              border-width: 0 2px;
              position: sticky;
              top: 0px;
              max-height: 100vh;
            }

            
        }

        @media screen and (max-width: 1024px) {

            #primary {flex-direction: column;}

            #main { border-width: 0 2px;}
            

            #sidebar {flex: 0 1 100%;}

            #sidebar nav ul ul {display: none;}

            #sidebar nav ul {
                display: flex; /*Treats list items like they're items in a flex div*/
                flex-wrap: wrap; /*Causes list items to go to the next line if the viewport isn't wide enough*/
                list-style-type: none; /*Removes bullets*/
                padding-left: 0; /*Removes default list indentation*/
                justify-content: center; /*Optional, aligns our list to the center of the div*/
                margin: 0.5em;
            }

            #sidebar nav ul li + li::before {
                content: var(--pixel); /*Decoration that goes in-between list items.*/
                margin: auto /*0.5em*/; /*Optional, extra spacing so it looks nicer*/
            }

            /*#sidebar a {display: revert;}*/

        }

        @media only screen and (max-width: 599px) {
            #container {
                max-width: 100%;
            }

            #header {
                min-height: 75px;
                /*change pixels to em*/
            }

            #siteTitle {
                left: 0;
                right: 0;
                margin: 0 auto;
            }

            #sidebar, #main, header, footer {
                border: none;
            }
        }

