        @supports (background-color: color-mix(in srgb, var(--accent-primary) 40%, transparent)) {
            mark {
              background-color: color-mix(in srgb, var(--accent-primary) 40%, transparent);
              color: var(--text);
              filter: saturate(120%);
            }
        }

        code {
          background-color: color-mix(in srgb, var(--text) 15%, transparent);
        }

        pre code {
          background: none;
        }



        pre {
                border: 1px solid var(--text);
