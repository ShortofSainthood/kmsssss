        * {
          box-sizing: border-box;
          scrollbar-color: var(--text) var(--bg);
          max-width: 100%
        }

        /* BODY */
        html, body {
          width: 100%;
          height: 100%;
          padding: 0;
          margin: 0;
        }
        body {
          font-size: 100%;
          font-family: var(--bodyfont);
          color: var(--text);
          background-color: var(--accent-secondary);
          background-image: var(--bgimg);
          background-size: var(--bgsize);
          background-attachment: fixed;
          background-position: center;
        }

        /* TEXT SELECT */
        ::selection {
          background: var(--accent-secondary);
          color: var(--bg);
        }

        /* FOCUS */
        *:focus-visible, .prev:has(a:focus-visible), .next:has(a:focus-visible), a:focus-visible img, a.warninglink:focus-visible {
          outline: var(--accent-secondary) solid 0.2rem;
          border-radius: 5px;
          outline-offset: .2rem;
          z-index: 100;
          position: relative;
        }
        a:has(img):focus-visible, .prev a:focus-visible, .next a:focus-visible {
          outline: 0;
        }

        /* CONTAINER */
        #container {
          margin: 0 auto;
          max-width: 95%;
          width: 1000px;
          flex-direction: column;
          height: fit-content;
          min-height: 100%;
        }
        #container, #primary {display: flex; flex-wrap: wrap;}
        #primary { flex: 1 1 100%;}

        /* FLEXBOX */
        .flexcontainer {display:flex; flex-wrap:wrap; margin:auto;}
        .full { flex: 1 1 100%;}
        .half { flex: 1 1 50%; }
        .third { flex: 1 1 33%; }
        .twothird { flex: 1 1 66%; }
        .quarter { flex: 1 1 25%; }
        .threequarter { flex: 1 1 75%; }
        figure .flexcontainer {gap: 0.5em;}
        figure .full {flex: 1 1 calc(100% - 0.5em); }
        figure .half {flex: 1 1 calc(50% - 0.5em); }
        figure .third {flex: 1 1 calc(33% - 0.5em); }
        .twothird { flex: 1 1 calc(66% - 0.5em); }
        .quarter { flex: 1 1 calc(25% - 0.5em); }
        .threequarter { flex: 1 1 calc(75% - 0.5em); }
        @media screen and (max-width: 1024px) {.flexcontainer, .container, .primary {display:block;}}
        
        /* LANDMARK REGIONS */

        #sidebar, #main, header, footer {
            border: 2px var(--text) solid;
            /*border-radius: 10px;*/
            background-color: var(--bg);
            /*font-size: 1.025rem;*/
        }


        header {
            background-color: var(--accent-primary);
            background-image: url("https://www.freecodecamp.org/news/content/images/size/w2000/2022/05/pexels-jack-hawley-57905.jpg");
            background-blend-mode: hard-light;
            background-size: contain;
            min-height: 150px;
            display: flex;
            justify-content: end;
            align-items: end;
            padding-right: 1em;
        }

        #headerArea {
          position: relative;
        }

        #siteTitle {
            font-size: 3em;
            width: fit-content;
