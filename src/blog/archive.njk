{% for year, posts in collections.posts | groupby("data.year") | dictsort | reverse %}
	<h2 id="{{ year }}">{{ year }}</h2>
  <ul>
	{% for post in posts | reverse %}
		<li>
			<time style="font-weight: bold;" datetime="{{ post.data.date }}">{{ post.data.date.toString() | niceDateShort2D }}</time> - <a href="{{ post.url }}">{{ post.data.title }}</a>
		</li>
	{% endfor %}
  </ul>
{% endfor %}


<p class="speciallink"><a href="/blog/">Back to Blog Index</a></p>