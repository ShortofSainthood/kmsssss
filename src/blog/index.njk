---
desc: Welcome to my blog! It's about as inconsistent as the rest of my site, but I hope you enjoy it anyway.
layout: blog.njk
pagination:
  data: collections.posts
  size: 10
  reverse: true
permalink: "{% if pagination.pageNumber == 0 %}/blog/index.html{% endif %}{% if pagination.pageNumber > 0 %}/blog/page/{{ pagination.pageNumber + 1 }}.html{% endif %}"
eleventyNavigation:
  key: Blog
  parent: Home
eleventyComputed:
  title: "{% if pagination.pageNumber == 0 %}Blog{% endif %}{% if pagination.pageNumber > 0 %}Blog - Page {{ pagination.pageNumber + 1 }}{% endif %}"
---
<h1>{{ title }}</h1>
{% for post in pagination.items %}
{% if not post.data.feedOnly %}
    {% include "post.html" %}
{% endif %}
{% endfor %}
<nav class="pagination" aria-label="pagination">
    {% include "pagination.html" %}
</nav>