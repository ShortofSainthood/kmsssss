---json
{
  "permalink": "/postroll.xml",
  "eleventyExcludeFromCollections": true,
  "metadata": {
    "title": "Sainthood.xyz Postroll",
    "description": "Your guess is as good as mine.",
    "language": "en",
    "base": "https://sainthood.xyz/blog/postroll",
    "author": {
      "name": "Saint"
    }
  }
}
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:dc="http://purl.org/dc/elements/1.1/" xml:base="{{ metadata.base | addPathPrefixToFullUrl }}" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ metadata.title }}</title>
    <link>{{ metadata.base | addPathPrefixToFullUrl }}</link>
    <atom:link href="{{ permalink | htmlBaseUrl(metadata.base) }}" rel="self" type="application/rss+xml" />
    <description>{{ metadata.description }}</description>
    <language>{{ metadata.language or page.lang }}</language>
    {% for post in postroll | sort(true, true, 'pubDate') %}
    <item>
      <title>{{ post.title }}</title>
      <link>{{ post.link }}</link>
      <description></description>
      <pubDate>{{ post.pubDate | dateToRfc822 }}</pubDate>
      <dc:creator>{{ post.author }}</dc:creator>
      <guid>{{ post.link }}</guid>
    </item>
    {%- endfor %}
  </channel>
</rss>